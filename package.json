{
  "name": "e-pharmacy",
  "module": "server.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/figlet": "^1.7.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@development-team/bg-remover": "^1.2.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/socket.io": "^3.0.1",
    "axios": "^1.13.1",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.1.2",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "figlet": "^1.9.3",
    "firebase-admin": "^13.6.0",
    "fuse.js": "^7.3.0",
    "google-auth-library": "^10.4.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.3.5",
    "mongoose": "^8.18.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "next-cloudinary": "^6.17.0",
    "node-mailjet": "^6.0.11",
    "nodemailer": "^7.0.6",
    "redis": "^5.8.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "scripts": {
    "start": "bun run server.ts",
    "dev": "bun --watch server.ts",
    "build": "tsc --declaration",
    "build:prod": "tsc --declaration --sourceMap false",
    "seed:flags": "npx ts-node scripts/seedFeatureFlags.ts",
    "format": "prettier --write .",
    "docker:build": "docker build -t e-pharmacy-backend .",
    "docker:run": "docker run -p 5000:5000 --env-file .env e-pharmacy-backend",
    "docker:up": "docker compose -f docker-compose.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml down",
    "docker:logs": "docker compose -f docker-compose.yml logs -f",
    "db:up": "docker compose -f docker-compose.yml up -d redis",
    "test": "bun test --concurrency=1",
    "test:watch": "bun test --watch --concurrency=1"
  }
}
