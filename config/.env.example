# Production / Global environment.
# Copy to config/.env and fill in real values. NEVER commit secrets.

NODE_ENV=production
PORT=5000

# Auth
USER_SECRET_KEY=
JWT_SECRET=

# MongoDB Atlas / managed cluster
DB_URI=

# Managed Redis (TLS required). Format: rediss://default:<pass>@<host>:<port>
REDIS_URL=
REDIS_KEY_PREFIX=svc1:prod:

# Service-to-service
INTERNAL_SERVICE_API_KEY=

# CORS (comma-separated origins, no wildcard in prod)
CORS_ORIGINS=

# Firebase Admin SDK (full JSON as a single line)
FIREBASE_STRING=

# Mail
SENDGRID_API_KEY=
MAIL_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
