# Local Docker dev environment.
# Copy to config/.env when running with `docker compose up`.

NODE_ENV=development
PORT=5000

# Auth — any non-empty random strings work locally.
USER_SECRET_KEY=local-dev-secret-change-me
JWT_SECRET=local-dev-secret-change-me

# Local MongoDB (uncomment mongo service in docker-compose.yml) OR Atlas dev DB
DB_URI=mongodb://localhost:27017/e-pharmacy

# Docker-compose Redis (NOT for prod use)
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=svc1:local:

# Service-to-service
INTERNAL_SERVICE_API_KEY=local-dev-internal-key

# CORS — wildcard is fine locally
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional in dev — leave blank to disable
FIREBASE_STRING=
SENDGRID_API_KEY=
MAIL_FROM=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
