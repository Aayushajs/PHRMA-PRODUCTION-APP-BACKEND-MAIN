  "item": [
    {
      "name": "📄 Prescription APIs",
      "item": [
        {
          "name": "Upload Single Prescription Image",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "prescription",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{gateway_url}}/api/prescription/upload",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "api",
                "prescription",
                "upload"
              ]
            },
            "description": "Upload a single prescription image for OCR processing.\n\n**Headers:**\n- `Authorization: Bearer {{auth_token}}`\n\n**Response Time:** 15-25 seconds"
          },
          "response": []
        },
        {
          "name": "Upload Prescription with Stream (Real-time)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "prescription",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{gateway_url}}/api/prescription/upload-stream",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "api",
                "prescription",
                "upload-stream"
              ]
            },
            "description": "Upload prescription with real-time streaming updates via Server-Sent Events (SSE).\n\n**Note:** Use EventSource in browser or enable streaming in Postman.\n\n**Response Format:** SSE with progress events"
          },
          "response": []
        }
      ]
    },
    {
      "name": "🔍 Search APIs",
      "item": [
        {
          "name": "Search Medicines by Prescription (Filtered)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prescriptionId\": \"{{prescription_id}}\",\n  \"userLocation\": {\n    \"latitude\": 19.0760,\n    \"longitude\": 72.8777\n  },\n  \"filters\": {\n    \"maxPrice\": 500,\n    \"maxDistance\": 5,\n    \"availability\": \"in_stock\"\n  }\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/search",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "api",
                "search"
              ]
            },
            "description": "Search medicines from a prescription with optional filters for price, distance, and availability.\n\n**Required Body:**\n- `prescriptionId` (string)\n\n**Optional Filters:**\n- `maxPrice` (number)\n- `maxDistance` (number, km)\n- `availability` (string: in_stock, out_of_stock)\n\n**Response:** Medicine-view and store-view aggregated data"
          },
          "response": []
        },
        {
          "name": "Global Medicine Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/search/global?q=aspirin&lat=19.0760&lng=72.8777&limit=20",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "api",
                "search",
                "global"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "aspirin",
                  "description": "Search query (medicine name)"
                },
                {
                  "key": "lat",
                  "value": "19.0760",
                  "description": "Latitude (optional)"
                },
                {
                  "key": "lng",
                  "value": "72.8777",
                  "description": "Longitude (optional)"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Results limit (default: 10)"
                }
              ]
            },
            "description": "Search medicines globally across all stores.\n\n**Query Parameters:**\n- `q` (required): Medicine name\n- `lat`, `lng` (optional): For distance calculation\n- `limit` (optional): Max results (default 10)\n\n**Note:** No authentication required"
          },
          "response": []
        }
      ]
    },
    {
      "name": "🛒 Bucket/Cart APIs",
      "item": [
        {
          "name": "Get User Bucket",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/bucket?prescriptionId={{prescription_id}}",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "api",
                "bucket"
              ],
              "query": [
                {
                  "key": "prescriptionId",
                  "value": "{{prescription_id}}",
                  "description": "Prescription ID (optional)"
                }
              ]
            },
            "description": "Retrieve user's bucket with all items from different stores.\n\n**Query Parameters:**\n- `prescriptionId` (optional): Filter by prescription\n\n**Response:** Bucket collections grouped by store"
          },
          "response": []
        },
        {
          "name": "Add Medicine to Bucket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prescriptionId\": \"{{prescription_id}}\",\n  \"store\": {\n    \"storeId\": \"{{store_id}}\",\n    \"storeName\": \"City Pharmacy\",\n    \"storeLocation\": {\n      \"latitude\": 19.0765,\n      \"longitude\": 72.8765\n    },\n    \"medicines\": [\n      {\n        \"medicineId\": \"{{medicine_id}}\",\n        \"medicineName\": \"Aspirin\",\n        \"dosage\": \"500mg\",\n        \"price\": 45,\n        \"quantity\": 2\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/bucket/add",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "api",
                "bucket",
                "add"
              ]
            },
            "description": "Add medicines from a store to user's bucket.\n\n**Required Fields:**\n- `prescriptionId`: Related prescription\n- `store`: Store object with medicines array"
          },
          "response": []
        },
        {
          "name": "Remove Medicine from Bucket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prescriptionId\": \"{{prescription_id}}\",\n  \"storeId\": \"{{store_id}}\",\n  \"medicineId\": \"{{medicine_id}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/bucket/remove",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "api",
                "bucket",
                "remove"
              ]
            },
            "description": "Remove a specific medicine or entire store from user's bucket.\n\n**Required Fields:**\n- `prescriptionId`\n- `storeId`\n- `medicineId` (optional, if omitted removes entire store)"
          },
          "response": []
        }
      ]
    },
